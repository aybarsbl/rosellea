{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GRADLE_OPTS": "-Xmx4096m -XX:MaxMetaspaceSize=1024m",
        "JAVA_TOOL_OPTIONS": "-Xmx4096m -XX:MaxMetaspaceSize=1024m"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
