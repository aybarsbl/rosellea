<?xml version="1.0" encoding="utf-8"?>
<!--
    Wear OS splash icon. Klasik "loading" görünümü: tam halka soluk gri,
    üstünde üst-sağ çeyrekte parlak yay. Statik vector; SplashScreen API
    canvas'ı zaten merkeze çiziyor.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Arka halka (soluk) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="4"
        android:pathData="M24,8
                          a16,16 0 1,0 0.001,0 Z" />

    <!-- Aktif yay (parlak, ~120° üst-sağ çeyrek) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M24,8
                          A16,16 0 0,1 37.86,16" />
</vector>