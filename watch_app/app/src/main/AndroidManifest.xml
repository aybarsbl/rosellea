<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!--
        Android 15 (API 35) BODY_SENSORS'u deprecate etti; API 36 hedefli uygulamada
        BODY_SENSORS isteği runtime'da dialog ÜRETMİYOR ve Ayarlar > İzinler altında
        görünmüyor. Yeni isim: android.permission.health.READ_HEART_RATE. Eski cihaz
        kalmadığı için (minSdk=36) BODY_SENSORS'u tamamen kaldırıyoruz.
    -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <!--
        Android 13'ten itibaren arkaplan sensör erişimi için ayrı izin
        gerekiyor. Foreground service type=health ile birlikte runtime'da
        ayrı bir prompt çıkmıyor (bir defalık birleşik dialogla geliyor)
        ama izni mutlaka manifestte beyan etmek lazım, yoksa system
        screen-off'ta sensor stream'ini kesiyor.
    -->
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <!--
        One UI Watch'un "Sleeping apps" listesi foreground service bile olsa
        uzun süre CPU/sensor tutan uygulamayı uyutabiliyor. Bu izin kullanıcıdan
        battery optimization muafiyeti istemek için zorunlu.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <uses-feature android:name="android.hardware.type.watch" />
    <uses-feature
        android:name="android.hardware.sensor.heartrate"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">
        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />
        <uses-library
            android:name="wear-sdk"
            android:required="false" />

        <!--
               Standalone Wear OS uygulaması: companion telefon app'ine ihtiyaç
               duymadan çalışır. BPM köprüsü Wearable Data Layer üzerinden eşli
               telefondaki Rosellea app'ine gider, ona companion gerekmez.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@style/MainActivityTheme.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.HrForegroundService"
            android:exported="false"
            android:foregroundServiceType="health" />
    </application>

</manifest>
